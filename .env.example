# Recommended: Sign in with Google (uses your Chrome/Google account via OAuth)
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorized redirect URI: http://localhost:3000/api/auth/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Poll Google Sheet for new tickets (seconds). Default: 60
NEXT_PUBLIC_AUTO_REFRESH_SECONDS=60

# Optional fallback: service account (share sheet with service account email)
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Optional: default sheet if none configured in UI
DEFAULT_SHEET_URL=https://docs.google.com/spreadsheets/d/1Kj8p-USf20vZREe-Cxg2c28vq4ppTwmgr05lYGxJebg/edit?gid=223304028

# Salesforce unified search (Column R) — email from Column D is URL-encoded
SALESFORCE_SEARCH_BASE_URL=https://airbnbnimbus.my.salesforce.com/_ui/search/ui/UnifiedSearchResults
# NEXT_PUBLIC_SALESFORCE_SEARCH_BASE_URL=  # optional; use lightning URL if preferred

# Legacy Gmail env (not needed when using Sign in with Google)
GMAIL_SENDER_EMAIL=

# Overlay database path (default: ./data/overlay.db)
OVERLAY_DB_PATH=./data/overlay.db

# Release Gmail thread claims on tickets closed longer than this many days (default: 90)
# GMAIL_LINK_ARCHIVE_DAYS=90

# Market Manager name→email directory (default: ./data/market-managers.json)
# MARKET_MANAGERS_PATH=./data/market-managers.json

# Mixmax templates (optional) — Settings → Integrations → API token (Growth+ plan)
# https://developer.mixmax.com/reference/getting-started-with-the-api
MIXMAX_API_TOKEN=

# Use mock ticket data when Google credentials are missing
USE_MOCK_DATA=true
